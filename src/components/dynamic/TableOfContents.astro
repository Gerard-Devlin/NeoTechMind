---
interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props
---

{
  headings.length > 0 && (
    <nav class='not-prose rounded-2xl border bg-muted/30 p-4'>
      <h2 class='text-sm font-semibold tracking-wide text-muted-foreground uppercase'>目录</h2>
      <ul class='mt-3 flex flex-col gap-2'>
        {headings.map((heading) => (
          <li style={`padding-left:${(heading.depth - 1) * 0.75}rem`}>
            <a class='text-sm text-foreground/80 hover:text-foreground' href={`#${heading.slug}`}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
