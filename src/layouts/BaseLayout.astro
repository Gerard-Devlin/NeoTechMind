---
import { Footer, ThemeProvider } from 'astro-pure/components/basic'
import type { SiteMeta } from 'astro-pure/types'
import BaseHead from '@/components/BaseHead.astro'
import SiteHeader from '@/components/dynamic/SiteHeader.astro'
import config from '@/site-config'

import 'katex/dist/katex.min.css'
import '@/assets/styles/global.css'
import '@/assets/styles/app.css'

interface Props {
  meta: SiteMeta
  highlightColor?: string
  containerClass?: string
}

const {
  meta: { articleDate, description = config.description, ogImage, title },
  highlightColor,
  containerClass = 'max-w-[70rem]',
  ...props
} = Astro.props

const pathname = Astro.url.pathname
---

<html lang={config.locale.lang}>
  <head>
    <BaseHead {articleDate} {description} {ogImage} {title} />
    <link rel='preconnect' href='https://cdn.jsdelivr.net' />
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/katex@0.16.33/dist/katex.min.css'
      crossorigin='anonymous'
    />
    <script is:inline>
      (() => {
        const FALLBACK_CLASS = 'katex-mathml-fallback'

        const enableMathmlFallback = () => {
          document.documentElement.classList.add(FALLBACK_CLASS)
        }

        const verifyKatexFont = () => {
          if (!('fonts' in document) || !document.fonts) {
            enableMathmlFallback()
            return
          }

          const loaded =
            document.fonts.check('16px KaTeX_Main') ||
            document.fonts.check('16px "KaTeX_Main"') ||
            document.fonts.check('16px KaTeX_Math') ||
            document.fonts.check('16px "KaTeX_Math"')

          if (!loaded) {
            enableMathmlFallback()
          }
        }

        if ('fonts' in document && document.fonts?.ready) {
          Promise.race([
            document.fonts.ready,
            new Promise((resolve) => window.setTimeout(resolve, 1800))
          ]).then(() => verifyKatexFont())
        } else if (document.readyState === 'complete') {
          verifyKatexFont()
        } else {
          window.addEventListener('load', verifyKatexFont, { once: true })
        }
      })()
    </script>
    <ThemeProvider />
  </head>

  <body class='flex justify-center bg-background text-foreground' {...props}>
    {
      highlightColor && (
        <div
          id='highlight-gradient'
          class='pointer-events-none absolute start-0 top-0 z-0 h-screen w-full opacity-25'
          style={`background-image:linear-gradient(${highlightColor},transparent)`}
        />
      )
    }

    <div id='main-container' class:list={['min-h-[100dvh] w-full flex flex-col justify-between', containerClass]}>
      <SiteHeader pathname={pathname} />

      <div class='w-full flex-1'>
        <slot />
      </div>

      <Footer />
    </div>

    <style define:vars={{ highlightColor }}>
      :global(.highlight) {
        --highlight-fg: color-mix(
          in srgb,
          var(--highlightColor) 40%,
          hsl(var(--foreground) / var(--un-text-opacity, 1))
        );
        color: var(--highlight-fg, hsl(var(--primary) / var(--un-text-opacity))) !important;
      }

      :global(.highlight-bg) {
        background-color: var(
          --highlightColor,
          hsl(var(--primary) / var(--un-text-opacity))
        ) !important;
      }

      #main-container {
        padding-top: env(safe-area-inset-top);
        padding-left: calc(1rem + env(safe-area-inset-left));
        padding-right: calc(1rem + env(safe-area-inset-right));
      }

      @media (min-width: 640px) {
        #main-container {
          padding-left: calc(1.75rem + env(safe-area-inset-left));
          padding-right: calc(1.75rem + env(safe-area-inset-right));
        }
      }

      @media (min-width: 1024px) {
        #main-container {
          padding-left: calc(2.5rem + env(safe-area-inset-left));
          padding-right: calc(2.5rem + env(safe-area-inset-right));
        }
      }
    </style>
  </body>
</html>
